# ── Servidor ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos PostgreSQL ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=servicio_tecnico

# ── Autenticación JWT ──────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── CORS ───────────────────────────────────────────────
FRONTEND_URL=https://servicio-tecnico-frontend.vercel.app

# ── Cloudinary (almacenamiento de fotos) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── BSale (facturación electrónica) ────────────────────
BSALE_TOKEN=
# IDs de configuración BSale — obtener desde /bsale/config
BSALE_DOCUMENT_TYPE_ID=1
BSALE_OFFICE_ID=1
BSALE_PRICE_LIST_ID=1

# ── Notificaciones (opcional) ──────────────────────────
# URL de webhook para notificar al cliente cuando su equipo está reparado
# Compatible con Make.com, Zapier, n8n, etc.
# Si está vacío, las notificaciones se deshabilitan silenciosamente
NOTIFICACION_WEBHOOK_URL=
